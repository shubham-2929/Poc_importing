# Ignition GitFlow CI/CD - Git Ignore

# Build artifacts
build/
*.zip

# Backup files
backups/*/*
!backups/.gitkeep
!backups/dev/.gitkeep
!backups/staging/.gitkeep
!backups/prod/.gitkeep
!backups/local/.gitkeep

# Ignition Local Configuration (per curated mounts approach)
# See: https://docs.inductiveautomation.com/docs/8.3/tutorials/version-control-guide
**/config/local
**/config/resources/local
**/conversion-report.txt
**/.resources/

# Auto-created temp resources by Ignition
**/user-source/temp*/
**/identity-provider/temp*/
config/gateway/resources/migration-log-*.md

# Version-Controlled Gateway Configuration
# config/gateway/ - Source of truth for gateway config (version controlled)
# Note: Runtime-specific paths are excluded below via **/config/local patterns

# Environment-specific deployments (not version controlled)
# - ignition-local: Local development workspace (config can diverge from version control)
# - ignition-dev/staging/prod: CI/CD deployment targets (receive config from config/gateway/)

# CI/CD deployment environments - exclude everything
services/ignition-dev/
services/ignition-staging/
services/ignition-prod/

# Local development environment - exclude entire config (can diverge from source)
services/ignition-local/config/
!services/ignition-local/config/.gitkeep
services/ignition-local/projects/*

# Requirements
requirements/

# Ignition runtime data (never commit these)
ignition-data/
**/data/var/
**/data/local/
**/data/logs/
**/data/metro-keystore
**/data/.uuid
*.gwbk
*.idb

# Docker volumes
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/

# Environment-specific secrets (use Azure DevOps variables instead)
.env
.env.local
secrets/
*.key
*.pem

# Database dumps
*.sql.gz
*.dump

# OS-specific
Thumbs.db
.DS_Store

# Node modules (if using any Node.js tools)
node_modules/

# Test coverage
.coverage
htmlcov/
.pytest_cache/
