# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
# Optional fallback for API token only: secrets/gateway_api_key

# Local
LOCAL_GATEWAY_URL=http://localhost:9088
LOCAL_GATEWAY_USER=admin
LOCAL_GATEWAY_PASS=Test123!
LOCAL_GATEWAY_API_KEY=replace-with-api-token
LOCAL_DB_URL=postgres://ignition:replace-with-db-password@localhost:5432/ignition_local?sslmode=disable

# Development
DEV_GATEWAY_URL=http://localhost:8088
DEV_GATEWAY_USER=admin
DEV_GATEWAY_PASS=Test123!
DEV_GATEWAY_API_KEY=replace-with-api-token
DEV_DB_URL=postgres://ignition:replace-with-db-password@localhost:5432/ignition_dev?sslmode=disable

# Staging
STAGING_GATEWAY_URL=http://localhost:8188
STAGING_GATEWAY_USER=admin
STAGING_GATEWAY_PASS=Test123!
STAGING_GATEWAY_API_KEY=replace-with-api-token
STAGING_DB_URL=postgres://ignition:replace-with-db-password@localhost:5432/ignition_staging?sslmode=disable

# Production
PROD_GATEWAY_URL=http://localhost:8288
PROD_GATEWAY_USER=admin
PROD_GATEWAY_PASS=Test123!
PROD_GATEWAY_API_KEY=replace-with-api-token
PROD_DB_URL=postgres://ignition:replace-with-db-password@localhost:5432/ignition_prod?sslmode=disable
